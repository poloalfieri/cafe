# ============================================================
# Backend – Flask  (cloná este archivo como .env)
# ============================================================

# ---------- App secret ----------
# Generá uno con: python3 -c 'import secrets; print(secrets.token_hex(32))'
SECRET_KEY=changeme

# ---------- Flask mode ----------
# development | production
FLASK_ENV=development
FLASK_DEBUG=true

# ---------- Supabase ----------
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=eyJhbGciOi...

# ---------- Database ----------
# Requerido para AFIP advisory lock (pg_advisory_xact_lock).
# En Supabase: Settings > Database > Connection string > URI
# Formato: postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:changeme@db.xxxx.supabase.co:5432/postgres
USE_ORM=true

# ---------- Multi-tenant security ----------
# Debe coincidir con INTERNAL_PROXY_KEY del frontend
INTERNAL_PROXY_KEY=dev-internal-proxy-key-change-in-production

# ---------- Mercado Pago ----------
MERCADO_PAGO_ACCESS_TOKEN=TEST-xxxx
MERCADO_PAGO_PUBLIC_KEY=TEST-xxxx
MERCADO_PAGO_WEBHOOK_SECRET=

# ---------- URLs ----------
# En desarrollo:
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5001
BASE_URL=http://localhost:5001
# En producción:
# FRONTEND_URL=https://tu-app.vercel.app
# BACKEND_URL=https://tu-backend.onrender.com
# BASE_URL=https://tu-backend.onrender.com

# ---------- CORS ----------
# Orígenes permitidos (separados por coma). En producción, el dominio de Vercel.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# Producción:
# CORS_ORIGINS=https://tu-app.vercel.app

# ---------- Other ----------
PORT=5001
KITCHEN_WEBHOOK_URL=
TOKEN_EXPIRY_MINUTES=30

# ---------- AFIP / ARCA ----------
# Clave maestra AES-GCM (32 bytes en base64)
# Generar: python3 -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
AFIP_MASTER_KEY_B64=
